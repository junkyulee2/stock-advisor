# 춘규주식 환경 변수 템플릿
# 사용법: 이 파일을 .env로 복사한 후 값 채우세요. .env는 .gitignore에 들어있어 깃 추적 안 됨.
# 절대 실제 값을 .env.example에 적지 말 것 (이 파일은 깃에 올라감).

# ─── KRX 한국거래소 (pykrx historical fundamentals) ─────────────
# data.krx.co.kr 무료 회원가입 후 ID/비번. Phase A-3 walk-forward 백테스트 필수.
KRX_ID=your_krx_id_here
KRX_PW=your_krx_password_here

# ─── Discord Webhook (알림) ────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── GitHub (cloud_store.py — 클라우드 모드 매수/매도 액션) ─────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=junkyulee2/stock-advisor

# ─── Anthropic (Phase C AI 검증, 옵션 — Claude Code Max 사용 시 불필요) ──
# ANTHROPIC_API_KEY=sk-ant-...
